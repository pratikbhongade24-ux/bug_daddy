AWS_REGION=us-west-2
BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0

# Set to true if you want to force a dry run without contacting MCP servers.
DRY_RUN=false
PEER_TIMEOUT_SECONDS=20

# Base URL for execution-log callbacks. The agent appends
# /agent/executions/{session_id}/events.
# Local non-Docker: http://localhost:8000
# Docker Compose: http://backend:8000 or http://host.docker.internal:8000
# AWS AgentCore: https://bugdaddy.in/api
AGENT_EXECUTION_CALLBACK_URL=http://localhost:8000
AGENT_EXECUTION_LOG_SECRET=change-me

# Peer AgentCore runtimes
BUG_DADDY_URL=http://localhost:8081/invocations
REVIEWER_DADDY_URL=http://localhost:8082/invocations
SME_AGENT_URL=http://localhost:8083/invocations

# Slack MCP
SLACK_MCP_TRANSPORT=stdio
SLACK_MCP_COMMAND=npx
SLACK_MCP_ARGS=["-y","@your-org/slack-mcp-server"]
SLACK_MCP_TOOL_ALLOWLIST=["slack_create_channel","slack_post_message","slack_lookup_channel"]

# Jira MCP
# Native Jira REST tools are also available without an MCP server when these are set.
JIRA_BASE_URL=https://bugdaddy.atlassian.net
JIRA_PROJECT_KEY=SCRUM
JIRA_EMAIL=your-atlassian-login@example.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_REVIEWER_ACCOUNT_ID=
JIRA_REVIEWER_EMAIL=
JIRA_REVIEWER_DISPLAY_NAME=
JIRA_MCP_TRANSPORT=stdio
JIRA_MCP_COMMAND=npx
JIRA_MCP_ARGS=["-y","@your-org/jira-mcp-server"]
JIRA_MCP_TOOL_ALLOWLIST=["jira_create_issue","jira_assign_issue","jira_update_issue","jira_add_comment","jira_assign_to_reviewer","jira_transition_issue","jira_search_issues"]

# Bitbucket MCP
BITBUCKET_MCP_TRANSPORT=stdio
BITBUCKET_MCP_COMMAND=npx
BITBUCKET_MCP_ARGS=["-y","@your-org/bitbucket-mcp-server"]
BITBUCKET_MCP_TOOL_ALLOWLIST=["bitbucket_clone_repo","bitbucket_create_branch","bitbucket_commit","bitbucket_create_pull_request","bitbucket_get_file"]

# GitHub
GITHUB_TOKEN=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
