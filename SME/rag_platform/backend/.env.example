APP_NAME=SME RAG Platform
ENV=dev
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://postgres:postgres@pgvector:5432/app
REDIS_URL=redis://redis:6379/0
S3_BUCKET=sme-rag-documents

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=
AWS_PROFILE=

BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=qwen.qwen3-coder-30b-a3b-v1:0
USE_MOCK_BEDROCK=false

WIDGET_API_KEY=change-widget-key
ADMIN_API_KEY=change-admin-key
APP_VERSION=1.0.0
APPLICATION_NAME=bank-loan-production-platform
