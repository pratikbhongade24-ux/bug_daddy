# Copy to /opt/sonarqube/.env on EC2 and fill the secret values there.
# Do not commit real secrets.

AWS_REGION=ap-south-1
AWS_PROFILE=bug-daddy

S3_BUCKET=bugdaddy-sonar-reports
SONAR_PROJECT_KEY=bugdaddy
SONAR_PROJECT_NAME=BugDaddy
SONAR_REPO_PATH=/opt/sonarqube/bug_daddy

SONAR_DB_HOST=bugdaddy-sonarqube-postgres.ctkcsksi0yjl.ap-south-1.rds.amazonaws.com
SONAR_DB_PORT=5432
SONAR_DB_NAME=sonarqube
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=replace-with-generated-password

# Create this token after the first SonarQube login.
SONAR_TOKEN=replace-with-sonarqube-token
